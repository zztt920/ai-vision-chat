# ============================================
# AI 视讯助手 - 后端配置
# ============================================
# 复制此文件为 .env 并填写你的配置
# cp .env.example .env
# ============================================

# [必填] API 密钥
# 阿里云百炼 DashScope：https://dashscope.aliyun.com/
# 登录 → 模型广场 → API-KEY 管理 → 创建新密钥
API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [可选] API 基础地址
# 阿里云百炼兼容 OpenAI 格式: https://dashscope.aliyuncs.com/compatible-mode/v1
# SiliconFlow: https://api.siliconflow.cn/v1
API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# [可选] 使用的模型名称
# 阿里云百炼（支持视觉）: qwen3-vl-plus (推荐), qwen3-vl-flash, qwen-vl-plus, qwen-vl-max
# SiliconFlow（支持视觉）: Qwen/Qwen3-VL-8B-Instruct, Qwen/Qwen2.5-VL-7B-Instruct
MODEL=qwen3-vl-plus

# [可选] 后端服务端口
# PORT=3000

# [可选] 允许跨域访问的来源（逗号分隔，留空允许所有来源）
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# [可选] 环境模式 (development / production)
# NODE_ENV=development